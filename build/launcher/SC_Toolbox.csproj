<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <RootNamespace>SC_Toolbox</RootNamespace>
    <AssemblyName>SC_Toolbox</AssemblyName>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWindowsForms>false</UseWindowsForms>

    <!-- Single-file self-contained publish — Velopack ships exactly one .exe -->
    <PublishSingleFile>true</PublishSingleFile>
    <SelfContained>true</SelfContained>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
    <PublishReadyToRun>false</PublishReadyToRun>

    <!-- Branding -->
    <ApplicationIcon>..\..\assets\sc_toolbox.ico</ApplicationIcon>
    <Version>2.2.10</Version>
    <FileVersion>2.2.10</FileVersion>
    <Product>SC Toolbox</Product>
    <Company>SC Toolbox</Company>
    <Copyright>Copyright (c) 2026</Copyright>
  </PropertyGroup>

  <ItemGroup>
    <!-- Velopack SDK — provides VelopackApp.Build().Run() that vpk pack
         requires the entry exe to call. Also exposes UpdateManager so we
         can trigger update checks from the launcher down the road. -->
    <PackageReference Include="Velopack" Version="0.0.1298" />
  </ItemGroup>

</Project>
