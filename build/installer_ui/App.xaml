<Application x:Class="SC_Toolbox.Installer.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml"
             ShutdownMode="OnMainWindowClose">
    <Application.Resources>
        <!-- Sci-fi green accent matching the in-app HUD theme. -->
        <SolidColorBrush x:Key="AccentBrush" Color="#33dd88" />
        <SolidColorBrush x:Key="AccentBrushDim" Color="#22995a" />
        <SolidColorBrush x:Key="PanelBackBrush" Color="#cc0a0e14" />
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#3033dd88" />
        <SolidColorBrush x:Key="TextBrush" Color="#e6f0ff" />
        <SolidColorBrush x:Key="TextDimBrush" Color="#88a0b8" />
    </Application.Resources>
</Application>
